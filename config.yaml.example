
env: dev                          # 环境标识：dev/test/prod
mock_mode: false                   # 是否启用Mock模式（true=使用假数据，false=连接真实环境）

llm:
  api_key: YOUR_API_KEY_HERE     # LLM API密钥
  model: your-model-name          # 模型名称，如 MiniMax-M2.5
  base_url: https://your-api-endpoint/v1  # API base URL
  temperature: 0.1                 # 生成温度，越低越确定性

langsmith:
  enabled: false                   # 是否启用 LangSmith 链路追踪
  api_key: YOUR_LANGSMITH_KEY     # LangSmith API Key
  project: SOPRCA-RCA            # 项目名称


knowledge_base:
  # SOP 知识库
  sop_db_path: data/sop_knowledge.db
  chroma_path: data/chroma

  # 历史故障知识库
  history_fault_db_path: data/history_knowledge.db


kubernetes:
  kubeconfig: kubeconfig.yaml     # kubeconfig 文件路径（相对于项目根目录）
  default_namespace: default       # 默认命名空间


# jaeger:
#   enabled: false
#   endpoint: http://your-jaeger:30086/api/traces
#   service_name: sop-rca


prometheus:
  url: http://your-prometheus:9090  # Prometheus URL
  # username: YOUR_USERNAME        # 如果需要认证
  # password: YOUR_PASSWORD


anti_loop:
  max_iterations: 10              # 最大迭代次数
  max_no_gain_iterations: 3      # 连续无增益最大次数
